# Score updater provider: api-football or football-data.
SCORE_PROVIDER=api-football

API_FOOTBALL_KEY=your_api_key_here
API_FOOTBALL_LEAGUE_ID=
API_FOOTBALL_SEASON=2026

# Server-side football-data.org access only.
FOOTBALL_DATA_TOKEN=your_football_data_token_here
FOOTBALL_DATA_COMPETITION=WC
FOOTBALL_DATA_SEASON=2026

PORT=8787

# Server-side Supabase score updater only.
# Never place the service role key in frontend config or index.html.
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional score updater budget/dry-run controls.
SCORE_UPDATE_BUDGET_DAILY=100
SCORE_UPDATE_RESERVE=20
DRY_RUN=1
MOCK_FIXTURES=1
DISCOVER_FIXTURES=0
DISCOVER_LEAGUES=0
LEAGUE_SEARCH=World Cup
LEAGUE_COUNTRY=
FORCE=0
# MATCH_DATE=2026-06-11
